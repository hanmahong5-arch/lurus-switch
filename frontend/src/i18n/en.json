  "help": {
    "gateway": {
      "title": "What is the Gateway?",
      "body": "The gateway is a local API proxy that routes all your AI tool requests through a single endpoint. It handles authentication, model routing, usage tracking, and lets you switch between providers without reconfiguring each tool."
    },
    "healthScore": {
      "title": "Health Score",
      "body": "A composite score (0-100) measuring how well your AI development environment is configured. It checks runtime dependencies, tool installations, configuration health, gateway connectivity, and system environment."
    },
    "proxy": {
      "title": "API Proxy Settings",
      "body": "The proxy routes your AI tool requests through a relay server. Set your API endpoint and token here. If you have a Lurus account, your token is provided automatically."
    },
    "tools": {
      "title": "AI CLI Tools",
      "body": "These are command-line AI coding assistants. Each tool has its own config file. Lurus Switch manages them all from one place — install, configure, connect to the gateway, and keep them updated."
    },
    "mcp": {
      "title": "MCP Servers",
      "body": "Model Context Protocol (MCP) servers extend AI tools with additional capabilities like file access, web browsing, or database queries. Add presets here and they'll be injected into your tool configs."
    },
    "workspace": {
      "title": "Workspace",
      "body": "Manage prompt templates, context documents (like CLAUDE.md), and monitor running AI tool processes — all in one place."
    },
    "autostart": {
      "title": "Auto-start",
      "body": "When enabled, Lurus Switch launches minimized when your computer starts. The gateway will auto-start too if configured, so your AI tools are always ready."
    },
    "envVar": {
      "title": "Environment Variables",
      "body": "Some AI tools read API keys from environment variables. Lurus Switch can set these for you system-wide so tools work even outside this app."
    },
    "pathConfig": {
      "title": "PATH Configuration",
      "body": "Your system PATH tells the terminal where to find programs. If a tool is installed but 'command not found', its directory needs to be added to PATH."
    }
